{
  "name": "huyfive",
  "displayName": "Huyfive",
  "description": "A VS Code extension with SSH file operations",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:huyfive.buildAndRun",
    "onCommand:huyfive.listRemoteFiles",
    "onCommand:huyfive.openSettings"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "huyfive-explorer",
          "title": "Huyfive",
          "icon": "media/huyfive.svg"
        }
      ]
    },
    "views": {
      "huyfive-explorer": [
        {
          "id": "huyfive.operations",
          "name": "Operations"
        }
      ]
    },
    "commands": [
      {
        "command": "huyfive.buildAndRun",
        "title": "Build and Run",
        "category": "Huyfive",
        "icon": "$(play)"
      },
      {
        "command": "huyfive.listRemoteFiles",
        "title": "List Remote Directory Files",
        "category": "Huyfive",
        "icon": "$(database)"
      },
      {
        "command": "huyfive.openSettings",
        "title": "Open Settings",
        "category": "Huyfive",
        "icon": "$(settings)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "huyfive.listRemoteFiles",
          "when": "view == huyfive.operations",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/glob": "^8.0.0",
    "@types/node": "^18.11.0",
    "typescript": "^4.9.0",
    "eslint": "^8.35.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0"
  }
}
