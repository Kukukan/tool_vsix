{
  "name": "huyfive",
  "displayName": "Huyfive",
  "description": "Build and run projects on remote SSH hosts or locally.",
  "version": "0.1.0",
  "publisher": "your-publisher-name",
  "engines": {
    "vscode": "^1.95.0"
  },
  "workspaces": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:huyfive.listRemoteFiles",
    "onCommand:huyfive.buildAndRun",
    "onCommand:huyfive.openSettings",
    "onCommand:huyfive.runCustomCommand",
    "onView:huyfive.operations"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "huyfive.listRemoteFiles",
        "title": "List Remote Files",
        "category": "Huyfive"
      },
      {
        "command": "huyfive.buildAndRun",
        "title": "Build and Run",
        "category": "Huyfive"
      },
      {
        "command": "huyfive.openSettings",
        "title": "Settings",
        "category": "Huyfive"
      },
      {
        "command": "huyfive.runCustomCommand",
        "title": "Run Custom Command",
        "category": "Huyfive"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "huyfive",
          "title": "Huyfive",
          "icon": "media/huyfive.svg"
        }
      ]
    },
    "views": {
      "huyfive": [
        {
          "id": "huyfive.operations",
          "name": "Operations"
        }
      ]
    },
    "configuration": {
      "title": "Huyfive",
      "properties": {
        "huyfive.remotePath": {
          "type": "string",
          "default": "",
          "description": "Default remote path for file operations."
        },
        "huyfive.localDestination": {
          "type": "string",
          "default": "./downloads",
          "description": "Local folder to save downloaded files."
        },
        "huyfive.bashScriptPath": {
          "type": "string",
          "default": "",
          "description": "Path to the build script on the remote host."
        },
        "huyfive.localAppPath": {
          "type": "string",
          "default": "",
          "description": "Local application to run after build."
        },
        "huyfive.host": {
          "type": "string",
          "default": "",
          "description": "Remote SSH host."
        },
        "huyfive.port": {
          "type": "string",
          "default": "22",
          "description": "Remote SSH port."
        },
        "huyfive.repoPath": {
          "type": "string",
          "default": "",
          "description": "Remote repository path."
        },
        "huyfive.downloadHistory": {
          "type": "array",
          "default": [],
          "description": "History of downloaded paths."
        },
        "huyfive.buildMode": {
          "type": "string",
          "enum": [
            "flash",
            "user"
          ],
          "default": "user",
          "description": "Build mode: flash (Flash+COM ports) or user (standard config)"
        },
        "huyfive.savedConfigurations": {
          "type": "object",
          "default": {},
          "description": "Saved configuration profiles."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  }
}
