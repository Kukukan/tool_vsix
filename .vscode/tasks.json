{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "typescript",
      "tsconfig": "tsconfig.json",
      "isBackground": false,
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "watch",
      "type": "typescript",
      "tsconfig": "tsconfig.json",
      "isBackground": true,
      "watch": "src",
      "problemMatcher": "$tsc-watch",
      "group": "build"
    }
  ]
}
